# Supabase Postgres connection strings.
# DATABASE_URL uses the pooled connection (port 6543, pgbouncer), DIRECT_URL
# uses the direct connection (port 5432) for migrations.
DATABASE_URL="postgresql://postgres:password@localhost:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:password@localhost:5432/postgres"

# Auth.js
# Generate with: npx auth secret
AUTH_SECRET="replace-with-a-random-32-byte-secret"
